# Supabase Postgres connection string (Transaction pooler, port 6543).
# Get it from: Supabase Dashboard -> Connect -> Transaction pooler.
# The app connects with the dedicated `oea_app` role.
DATABASE_URL="postgresql://oea_app.<project-ref>:<password>@<pooler-host>:6543/postgres"

# SerpApi key for the Auto-Scan engine (free tier: serpapi.com).
# Without it, scans are skipped (the rest of the site works normally).
SERPAPI_KEY=""

# Optional: override the auto-scan search queries (comma separated).
# SCAN_QUERIES="Events in Bhubaneswar Odisha,Events in Cuttack Odisha,Upcoming events in Odisha"

# Protects /api/cron/auto-scan; Vercel sends it automatically for cron jobs.
CRON_SECRET=""

# Secret for signing admin session JWTs.
JWT_SECRET=""
