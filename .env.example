# Supabase Postgres connection string (Transaction pooler, port 6543).
# Get it from: Supabase Dashboard -> Connect -> Transaction pooler.
# The app connects with the dedicated `oea_app` role.
DATABASE_URL="postgresql://oea_app.<project-ref>:<password>@<pooler-host>:6543/postgres"

# SerpApi key for the Auto-Scan engine (free tier: serpapi.com).
# Without it, scans are skipped (the rest of the site works normally).
SERPAPI_KEY=""

# Optional: override the auto-scan search queries (comma separated).
# SCAN_QUERIES="Events in Bhubaneswar Odisha,Events in Cuttack Odisha,Upcoming events in Odisha"

# --- Social hashtag scanning (Instagram/Facebook — clubs, DJ nights, events) ---
# Meta forbids open hashtag scraping; use ONE of the two sanctioned routes below.
# If neither is set, the social scan is skipped (the rest of the site is fine).
#
# Route 1 — Official Instagram Graph API (free). Requires a Meta developer app,
# an Instagram Business/Creator account linked to a Facebook Page, the
# instagram_basic + instagram_manage_insights permissions, and a long-lived token.
# IG_USER_ID is that connected Instagram Business account's numeric ID.
IG_GRAPH_TOKEN=""
IG_USER_ID=""
#
# Route 2 — Third-party scraper (Apify Instagram Hashtag Scraper, paid).
APIFY_TOKEN=""
#
# Optional: override the hashtags scanned (comma separated, # optional).
# Keep it small — IG Graph allows ~30 unique hashtags per rolling 7 days.
# SCAN_HASHTAGS="bhubaneswarnightlife,djnightbhubaneswar,odishaevents,cuttackevents"

# Protects /api/cron/auto-scan; Vercel sends it automatically for cron jobs.
CRON_SECRET=""

# Secret for signing admin session JWTs.
JWT_SECRET=""
