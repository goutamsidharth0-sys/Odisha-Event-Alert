datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // SUPER_ADMIN, ADMIN
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?  // icon name (e.g., "Music", "Calendar", etc.)
  imageUrl    String?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model City {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  district    String?
  state       String   @default("Odisha")
  description String?
  imageUrl    String?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model Organizer {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  phone         String?
  whatsapp      String?
  email         String?
  instagramUrl  String?
  websiteUrl    String?
  logoUrl       String?
  status        String   @default("UNVERIFIED") // ACTIVE, INACTIVE, UNVERIFIED, VERIFIED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        Event[]
}

model Event {
  id               String       @id @default(uuid())
  title            String
  slug             String       @unique
  shortDescription String?
  description      String
  categoryId       String
  category         Category     @relation(fields: [categoryId], references: [id])
  cityId           String
  city             City         @relation(fields: [cityId], references: [id])
  organizerId      String?
  organizer        Organizer?   @relation(fields: [organizerId], references: [id])
  organizerType    String       @default("PUBLIC") // PUBLIC, PRIVATE, GOVERNMENT, SOCIAL
  eventType        String       @default("OFFLINE") // OFFLINE, ONLINE, HYBRID
  status           String       @default("DRAFT") // DRAFT, PENDING, PUBLISHED, REJECTED, EXPIRED, WATCHLIST
  startDate        DateTime
  endDate          DateTime?
  startTime        String?
  endTime          String?
  venueName        String
  address          String?
  district         String?
  googleMapUrl     String?
  priceType        String       @default("FREE") // FREE, PAID, REGISTRATION_REQUIRED, NOT_ANNOUNCED
  minPrice         Float?
  maxPrice         Float?
  registrationUrl  String?
  ticketingUrl     String?
  officialUrl      String?
  instagramUrl     String?
  posterUrl        String?
  bannerUrl        String?
  sourceName       String?
  sourceUrl        String?
  isFeatured       Boolean      @default(false)
  isTrending       Boolean      @default(false)
  isVerified       Boolean      @default(false)
  viewsCount       Int          @default(0)
  shareCount       Int          @default(0)
  seoTitle         String?
  seoDescription   String?
  createdBy        String?
  approvedBy       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  publishedAt      DateTime?
  images           EventImage[]
}

model EventImage {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl  String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model EventSubmission {
  id                String   @id @default(uuid())
  eventTitle        String
  category          String
  eventType         String
  organizerType     String   @default("PUBLIC") // PUBLIC, PRIVATE, GOVERNMENT, SOCIAL
  description       String
  startDate         DateTime
  endDate           DateTime?
  startTime         String?
  endTime           String?
  venueName         String
  address           String?
  city              String
  district          String?
  googleMapUrl      String?
  priceType         String
  ticketPrice       String?
  registrationUrl   String?
  posterUrl         String?
  organizerName     String
  contactPerson     String?
  phone             String?
  whatsapp          String?
  email             String?
  instagramUrl      String?
  promotionInterest String?  // comma-separated list or JSON
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED, NEEDS_INFO
  adminNotes        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  phone       String
  email       String
  companyName String?
  leadType    String   // EVENT_LISTING, ADVERTISING, SPONSORSHIP, GENERAL, PARTNERSHIP
  message     String
  sourcePage  String?
  status      String   @default("NEW") // NEW, CONTACTED, CONVERTED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  phone     String?
  city      String?
  interests String?  // comma-separated
  source    String?
  status    String   @default("ACTIVE") // ACTIVE, UNSUBSCRIBED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
